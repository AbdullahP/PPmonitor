# PostgreSQL
DATABASE_URL=postgresql://pokemon:pokemon@localhost:5432/pokemon_monitor
POSTGRES_PASSWORD=pokemon

# Discord
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
DISCORD_ADMIN_WEBHOOK=
DISCORD_DISCOVERY_WEBHOOK=
DISCORD_CHANNEL_ID=

# Redirect service
REDIRECT_BASE_URL=http://localhost:8080

# Bol.com (override to http://mock_server:8099 for dev via docker-compose.override.yml)
BOL_BASE_URL=https://www.bol.com

# Polling intervals (seconds)
POLL_INTERVAL_PRODUCT=10
POLL_INTERVAL_CATEGORY=60

# Dashboard auth
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme
